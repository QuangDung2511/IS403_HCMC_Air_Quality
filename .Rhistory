library(tidyverse)
install.packages("tidyverse")
install.packages("tidyverse")
#bài 1
# 1. Khởi tạo dữ liệu chuẩn từ Bảng 1
data <- data.frame(
X1 = c(2.5, 3.4, 3.5, 3.6, 3.4, 3.3, 3.6, 3.5, 2.5, 3.1, 3.2, 3.1, 3.5, 3.5, 3.4, 3.2, 2.5, 2.7),
X2 = c(30, 30, 45, 40, 40, 45, 40, 40, 30, 45, 40, 45, 45, 40, 30, 30, 30, 30),
Y  = c(19.3, 22.4, 24.5, 26.9, 25.3, 22.7, 25.6, 27.2, 21.6, 25.6, 24.0, 24.3, 27.3, 27.5, 21.2, 16.7, 18.4, 19.6)
)
# --- BÀI 1.1: HỒI QUY TUYẾN TÍNH BỘI ---
model11 <- lm(Y ~ X1 + X2, data = data)
c11 <- coef(model11) # Trích xuất hệ số
cat("=== KẾT QUẢ BÀI 1.1 ===\n")
cat(sprintf("Phương trình: Y = %.4f + %.4f*X1 + %.4f*X2\n",
c11[1], c11[2], c11[3]))
cat(sprintf("Adjusted R-squared: %.4f\n", summary(model11)$adj.r.squared))
# --- BÀI 1.2: TUYẾN TÍNH HÓA MÔ HÌNH PHI TUYẾN ---
# Tạo biến phụ trực tiếp để thực hiện hồi quy tuyến tính theo tham số [cite: 681, 689]
data$X3 <- 1 / data$X1
data$X4 <- 1 / (data$X1 * data$X2)
model12 <- lm(Y ~ X1 + X2 + X3 + X4, data = data)
c12 <- coef(model12)
cat("\n=== KẾT QUẢ BÀI 1.2 ===\n")
cat(sprintf("Phương trình: Y = %.4f + %.4f*X1 + %.4f*X2 + %.4f*X3 + %.4f*X4\n",
c12[1], c12[2], c12[3], c12[4], c12[5]))
cat(sprintf("Adjusted R-squared: %.4f\n", summary(model12)$adj.r.squared))
#Bài 2
# --- DỮ LIỆU ĐẦU VÀO ---
house_age <- c(33, 32, 32, 33, 32, 33, 32, 33, 32, 33, 32, 32, 32, 32, 32, 33, 32, 32, 32, 32, 28, 27, 28, 28, 28, 28, 28, 27, 28, 28, 28, 27, 27, 28, 27, 28, 28, 27, 27, 28, 27, 27)
sq_feet <- c(1812, 1914, 1842, 1812, 1836, 2028, 1732, 1850, 1791, 1666, 1852, 1620, 1692, 2372, 2372, 1666, 2123, 1620, 1731, 1666, 1520, 1484, 1588, 1598, 1484, 1484, 1520, 1701, 1484, 1468, 1520, 1520, 1484, 1520, 1668, 1588, 1784, 1484, 1520, 1520, 1684, 1581)
market_value <- c(90000, 104400, 93300, 91000, 101900, 108500, 87600, 96000, 89200, 88400, 100800, 96700, 87500, 114000, 113200, 87500, 116100, 94700, 86400, 87100, 83400, 79800, 81500, 87100, 82600, 78800, 87600, 94200, 82000, 88100, 88100, 88600, 76600, 84400, 90900, 81000, 91300, 81300, 100700, 87200, 96700, 120700)
df <- data.frame(house_age, sq_feet, market_value)
# --- BÀI 2.1: Hồi quy đơn biến ---
model21 <- lm(market_value ~ house_age, data = df)
summary(model21)
# --- BÀI 2.2: Hồi quy đa biến ---
model22 <- lm(market_value ~ house_age + sq_feet, data = df)
summary(model22)
# --- BÀI 2.3: Tính toán các chỉ số so sánh ---
calc_metrics <- function(model, actual) {
pred <- predict(model)
res <- actual - pred
mae <- mean(abs(res))
mse <- mean(res^2)
rmse <- sqrt(mse)
mape <- mean(abs(res / actual)) * 100
r2 <- summary(model)$r.squared
adj_r2 <- summary(model)$adj.r.squared
return(c(MAE=mae, MAPE=mape, MSE=mse, RMSE=rmse, R2=r2, Adj_R2=adj_r2))
}
metrics21 <- calc_metrics(model21, df$market_value)
metrics22 <- calc_metrics(model22, df$market_value)
# Hiển thị bảng so sánh
comparison <- rbind(Model_2.1 = metrics21, Model_2.2 = metrics22)
print(round(comparison, 4))
